ANTHROPIC_API_KEY=your_key_here
MODEL=claude-sonnet-4-20250514
DUCKDB_PATH=data/dau_experiment.db
MEMORY_DB_PATH=memory/datapilot_memory.db
FORECAST_BACKEND=prophet
REVENUE_PER_DAU=0.50
SEMANTIC_CACHE_HARD_THRESHOLD=0.92
SEMANTIC_CACHE_SOFT_THRESHOLD=0.80
LOG_LEVEL=INFO

# Analysis defaults (override to adapt to a different schema without code changes)
DEFAULT_METRIC=dau_rate
DEFAULT_COVARIATE=pre_session_count
DEFAULT_GUARDRAILS=notif_optout,d7_retained,session_count
DEFAULT_SEGMENT_COLS=platform,user_segment
DEFAULT_FUNNEL_STEPS=impression,click,install,d1_retain
SCHEMA_CACHE_PATH=memory/schema_cache.json
BASELINE_DAU=500000
MAX_TOKENS_SQL=512
MAX_TOKENS_NARRATIVE=2048

# Langfuse observability (optional — tracing is disabled if these are not set)
LANGFUSE_PUBLIC_KEY=pk-lf-your_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
